@model ProjetoEndereco.Models.Endereco

@{
    ViewData["Title"] = "Novo Endereço";
}

<div class="container mt-4">

    <h2>Novo Endereço</h2>

    <form asp-action="Create" method="post">

        <div class="row">

            <div class="col-md-3 mb-3">
                <label>CEP</label>

                <input asp-for="Cep"
       class="form-control"
       id="cep" />

<span asp-validation-for="Cep"
      class="text-danger"></span>

            </div>

            <div class="col-md-3 mb-3">
                <label>Número</label>

                <input asp-for="Numero"
       class="form-control"
       id="numero" />

<span asp-validation-for="Numero"
      class="text-danger"></span>

            </div>

        </div>

        <div class="mb-3">
            <label>Logradouro</label>

            <input asp-for="Logradouro"
       class="form-control"
       id="logradouro" />

<span asp-validation-for="Logradouro"
      class="text-danger"></span>

        </div>

        <div class="mb-3">
            <label>Complemento</label>

            <input asp-for="Complemento"
                   class="form-control" />
        </div>

        <div class="mb-3">
            <label>Bairro</label>

            <input asp-for="Bairro"
       class="form-control"
       id="bairro" />

<span asp-validation-for="Bairro"
      class="text-danger"></span>

        </div>

        <div class="row">

            <div class="col-md-6 mb-3">
                <label>Cidade</label>

                <input asp-for="Cidade"
       class="form-control"
       id="cidade" />

<span asp-validation-for="Cidade"
      class="text-danger"></span>

            </div>

            <div class="col-md-2 mb-3">
                <label>UF</label>

                <input asp-for="Uf"
       class="form-control"
       id="uf" />

<span asp-validation-for="Uf"
      class="text-danger"></span>

            </div>

        </div>

        <button type="submit"
                class="btn btn-success">
            Salvar
        </button>

        <a asp-action="Index"
           class="btn btn-secondary">
            Voltar
        </a>

    </form>

</div>

@section Scripts {

<script>

    document
        .getElementById("cep")
        .addEventListener("blur", function () {

        let cep = this.value.replace(/\D/g, '');

        if (cep.length === 8) {

            fetch(`https://viacep.com.br/ws/${cep}/json/`)
                .then(response => response.json())
                .then(data => {

                    if (!data.erro) {

                        document.getElementById("logradouro").value =
                            data.logradouro;

                        document.getElementById("bairro").value =
                            data.bairro;

                        document.getElementById("cidade").value =
                            data.localidade;

                        document.getElementById("uf").value =
                            data.uf;
                    }
                });
        }
    });

</script>

}
